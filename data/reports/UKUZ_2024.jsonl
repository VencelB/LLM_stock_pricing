5 \u043d\u0430\u043b\u043e\u0433 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u043b\u0441\u044f \u043f\u043e \u0441\u0442\u0430\u0432\u043a\u0435 20% \u043e\u0442 \u043d\u0430\u043b\u043e\u0433\u043e\u043e\u0431\u043b\u0430\u0433\u0430\u0435\u043c\u043e\u0439 \n\u043f\u0440\u0438\u0431\u044b\u043b\u0438 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438 . \u0412 \u0438\u044e\u043b\u0435 2024 \u0433\u043e\u0434\u0430 \u0432 \u0420\u043e\u0441\u0441\u0438\u0438 \u0431\u044b\u043b \u043f\u0440\u0438\u043d\u044f\u0442 \u043d\u043e\u0432\u044b\u0439 \u0444\u0435\u0434\u0435\u0440\u0430\u043b\u044c\u043d\u044b\u0439 \u0437\u0430\u043a\u043e\u043d, \u0432 \n\u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0438\u0438 \u0441 \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u0441 1 \u044f\u043d\u0432\u0430\u0440\u044f 2025 \u0433. \u0441\u0442\u0430\u0432\u043a\u0430 \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c \u0443\u0432\u0435\u043b\u0438\u0447\u0438 \u043b\u0430\u0441\u044c \u0441 20% \u0434\u043e \n25%. \u0414\u0430\u043d\u043d\u043e\u0435 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0435 \u0437\u0430\u043a\u043e\u043d\u043e\u0434\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430 \u043d\u0435 \u043f\u043e\u0432\u043b\u0438\u044f\u043b\u043e \u043d\u0430 \u0441\u0443\u043c\u043c\u044b \u0442\u0435\u043a\u0443\u0449\u0435\u0433\u043e \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c "}
