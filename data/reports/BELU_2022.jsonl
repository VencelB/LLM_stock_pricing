{"name": "BELU", "date": "2022", "content": "\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 (597) 37 (560) \n\u041d\u0435\u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b (87) (9) (96) \n\u0417\u0430\u043f\u0430\u0441\u044b (65) (26) (91) \n\u0414\u0435\u0431\u0438\u0442\u043e\u0440\u0441\u043a\u0430\u044f \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c (223) (303) (526) \n\u041a\u0440\u0435\u0434\u0438\u0442\u043e\u0440\u0441\u043a\u0430\u044f \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c (94) 78 (16) \n\u041f\u0440\u043e\u0447\u0438\u0435 \u0430\u043a\u0442\u0438\u0432\u044b \u0438 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430 (11) 2 (9) \n\u0418\u0442\u043e\u0433\u043e \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0435 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0435 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430 (1 077) (221) (1 298) \n \n\u0427\u0438\u0441\u0442\u044b\u0439 \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0439 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0439 \u0430\u043a\u0442\u0438\u0432 709 (412) 297 \n\u0412\u044b\u0448\u0435 \u0432 \u0442\u0430\u0431\u043b\u0438\u0446\u0430\u0445 \u043f\u043e\u043a\u0430\u0437\u0430\u043d\u044b \u043f\u0440\u0438\u0437\u043d\u0430\u043d\u0438\u0435 \u0438 \u0440\u0435\u0432\u0435\u0440\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 \u0432\u0440\u0435\u043c\u0435\u043d\u043d\u044b\u0445 \u0440\u0430\u0437\u043d\u0438\u0446, \u043e\u0431\u0440\u0430\u0437\u0443\u044e\u0449\u0438\u0445\u0441\u044f, \u0432 \u043e\u0441\u043d\u043e\u0432\u043d\u043e\u043c, \u043e\u0442 \n\u043f\u0435\u0440\u0435\u043e\u0446\u0435\u043d\u043a\u0438 \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0438 \u043d\u0435\u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0445 \u0430\u043a\u0442\u0438\u0432\u043e\u0432 \u043f\u0440\u0438 \u043f\u0440\u0438\u043e\u0431\u0440\u0435\u0442\u0435\u043d\u0438\u0438 \u0434\u043e\u0447\u0435\u0440\u043d\u0438\u0445 \u043e\u0440\u0433\u0430\u043d\u0438\u0437\u0430\u0446\u0438\u0439, \n\u043e\u0431\u0435\u0441\u0446\u0435\u043d\u0435\u043d\u0438\u044f \u0434\u0435\u0431\u0438\u0442\u043e\u0440\u0441\u043a\u043e\u0439 \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u0438, \u0441\u043f\u0438\u0441\u0430\u043d\u0438\u044f \u0437\u0430\u043f\u0430\u0441\u043e\u0432 \u0434\u043e \u0447\u0438\u0441\u0442\u043e\u0439 \u0432\u043e\u0437\u043c\u043e\u0436\u043d\u043e\u0439 \u0446\u0435\u043d\u044b \u043f\u0440\u043e\u0434\u0430\u0436\u0438, \u0430 \u0442\u0430\u043a\u0436\u0435 \n\u043f\u0440\u0438 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u0438 \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0445 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0445 \u0430\u043a\u0442\u0438\u0432\u043e\u0432, \u043d\u0430\u0447\u0438\u0441\u043b\u0435\u043d\u043d\u044b\u0445 \u0441 \u0441\u0443\u043c\u043c\u044b \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0445 \u0443\u0431\u044b\u0442\u043a\u043e\u0432. \n26. \u041f\u0420\u0418\u0411\u042b\u041b\u042c \u041d\u0410 \u0410\u041a\u0426\u0418\u042e \n\u0411\u0430\u0437\u043e\u0432\u0430\u044f \u043f\u0440\u0438\u0431\u044b\u043b\u044c \u043d\u0430 \u0430\u043a\u0446\u0438\u044e \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u0442\u0441\u044f \u043a\u0430\u043a \u0440\u0435\u0437\u0443\u043b\u044c\u0442\u0430\u0442 \u0434\u0435\u043b\u0435\u043d\u0438\u044f \u043f\u0440\u0438\u0431\u044b\u043b\u0438 \u0438\u043b\u0438 \u0443\u0431\u044b\u0442\u043a\u0430, \u043f\u0440\u0438\u0445\u043e\u0434\u044f\u0449\u0438\u0445\u0441\u044f \u043d\u0430 \n\u0430\u043a\u0446\u0438\u043e\u043d\u0435\u0440\u043e\u0432 \u043c\u0430\u0442\u0435\u0440\u0438\u043d\u0441\u043a\u043e\u0439 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0438, \u043d\u0430 \u0441\u0440\u0435\u0434\u043d\u0435\u0432\u0437\u0432\u0435\u0448\u0435\u043d\u043d\u043e\u0435 \u043a\u043e\u043b\u0438\u0447\u0435\u0441\u0442\u0432\u043e \u043e\u0431\u044b\u043a\u043d\u043e\u0432\u0435\u043d\u043d\u044b\u0445 \u0430\u043a\u0446\u0438\u0439, \u043d\u0430\u0445\u043e\u0434\u044f\u0449\u0438\u0445\u0441\u044f "}
{"name": "BELU", "date": "2022", "content": "\u0427\u0438\u0441\u0442\u044b\u0435 \u0437\u0430\u0442\u0440\u0430\u0442\u044b \u043d\u0430 \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 (27) \n\u041d\u0430\u043b\u043e\u0433 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c - \n\u0423\u0431\u044b\u0442\u043e\u043a \u0437\u0430 \u043f\u0435\u0440\u0438\u043e\u0434 (316) \n\u0423\u0431\u044b\u0442\u043e\u043a, \u043f\u0440\u0438\u0437\u043d\u0430\u043d\u043d\u044b\u0439 \u043f\u0440\u0438 \u0434\u043e\u0432\u0435\u0434\u0435\u043d\u0438\u0438 \u0434\u043e \u0441\u043f\u0440\u0430\u0432\u0435\u0434\u043b\u0438\u0432\u043e\u0439 \u0441\u0442\u043e\u0438\u043c\u043e\u0441\u0442\u0438 (26) \n\u041f\u0440\u0435\u043a\u0440\u0430\u0449\u0430\u0435\u043c\u0430\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c, \u0443\u0431\u044b\u0442\u043e\u043a (342) \n27.3. \u0414\u0435\u043d\u0435\u0436\u043d\u044b\u0435 \u043f\u043e\u0442\u043e\u043a\u0438 \n\u0414\u0435\u043d\u0435\u0436\u043d\u044b\u0435 \u043f\u043e\u0442\u043e\u043a\u0438, \u043e\u0442\u043d\u043e\u0441\u044f\u0449\u0438\u0435\u0441\u044f \u043a \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u043e\u0439, \u0438\u043d\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u043e\u043d\u043d\u043e\u0439 \u0438 \u0444\u0438\u043d\u0430\u043d\u0441\u043e\u0432\u043e\u0439 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 \n\u0412\u044b\u0431\u044b\u0432\u0430\u044e\u0449\u0435\u0439 \u0433\u0440\u0443\u043f\u043f\u044b, \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u044b \u0432 \u043a\u043e\u043d\u0441\u043e\u043b\u0438\u0434\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u043e\u043c \u043e\u0442\u0447\u0435\u0442\u0435 \u043e \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0438 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0441\u043e\u0432\u043c\u0435\u0441\u0442\u043d\u043e \n\u0441 \u043f\u043e\u0442\u043e\u043a\u0430\u043c\u0438 \u043e\u0442 \u043f\u0440\u043e\u0434\u043e\u043b\u0436\u0430\u044e\u0449\u0435\u0439\u0441\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438, \u0430 \u0442\u0430\u043a\u0436\u0435 \u043f\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043b\u0435\u043d\u044b \u043d\u0438\u0436\u0435 \u0432 \u0442\u0430\u0431\u043b\u0438\u0446\u0435: \n 2020 \u0433\u043e\u0434 \n \n\u041f\u0440\u0435\u043a\u0440\u0430\u0449\u0430\u0435\u043c\u0430\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c, \u0443\u0431\u044b\u0442\u043e\u043a (342) \n\u0427\u0438\u0441\u0442\u044b\u0435 \u0437\u0430\u0442\u0440\u0430\u0442\u044b \u043d\u0430 \u0444\u0438\u043d\u0430\u043d\u0441\u0438\u0440\u043e\u0432\u0430\u043d\u0438\u0435 27 \n\u041e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u044b\u0439 \u0443\u0431\u044b\u0442\u043e\u043a, \u043f\u0440\u0435\u043a\u0440\u0430\u0449\u0430\u0435\u043c\u0430\u044f \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u044c (315) \n\u0418\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u043e\u0431\u043e\u0440\u043e\u0442\u043d\u043e\u043c \u043a\u0430\u043f\u0438\u0442\u0430\u043b\u0435 215 \n\u0427\u0438\u0441\u0442\u044b\u0439 \u043f\u043e\u0442\u043e\u043a \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u043e\u0442 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u043e\u043d\u043d\u043e\u0439 \u0434\u0435\u044f\u0442\u0435\u043b\u044c\u043d\u043e\u0441\u0442\u0438 (100) "}
{"name": "BELU", "date": "2022", "content": "\u0412 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0433\u043e\u0434\u0430, \u0437\u0430\u043a\u043e\u043d\u0447\u0438\u0432\u0448\u0435\u0433\u043e\u0441\u044f 31 \u0434\u0435\u043a\u0430\u0431\u0440\u044f 2021 \u0433\u043e\u0434\u0430 \u0438 31 \u0434\u0435\u043a\u0430\u0431\u0440\u044f 2020 \u0433\u043e\u0434\u0430, \u0431\u044b\u043b\u0438 \u043f\u0440\u0438\u043c\u0435\u043d\u0438\u043c\u044b \u0441\u043b\u0435\u0434\u0443\u044e\u0449\u0438\u0435 \n\u0441\u0442\u0430\u0432\u043a\u0438 \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c: \u0420\u043e\u0441\u0441\u0438\u0439\u0441\u043a\u0430\u044f \u0424\u0435\u0434\u0435\u0440\u0430\u0446\u0438\u044f \u2013 20%, \u041a\u0438\u043f\u0440 \u2013 12,5%. \n\u041d\u0438\u0436\u0435 \u043f\u0440\u0438\u0432\u0435\u0434\u0435\u043d \u0430 \u0441\u0432\u0435\u0440\u043a\u0430 \u0444\u0430\u043a\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0433\u043e \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043d\u0430\u043b\u043e\u0433\u043e\u043e\u0431\u043b\u0430\u0433\u0430\u0435\u043c\u0443\u044e \u043f\u0440\u0438\u0431\u044b\u043b\u044c \u0413\u0440\u0443\u043f\u043f\u044b \u0438 \u0442\u0435\u043e\u0440\u0435\u0442\u0438\u0447\u0435\u0441\u043a\u043e\u0439 \n\u0441\u0443\u043c\u043c\u044b, \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u044b\u0432\u0430\u0435\u043c\u043e\u0439 \u0441 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u043e\u0432\u0430\u043d\u0438\u0435\u043c \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0445 \u0441\u0442\u0430\u0432\u043e\u043a , \u043f\u0440\u0438\u043c\u0435\u043d\u0438\u043c\u044b\u0445 \u043a \u043f\u0440\u0438\u0431\u044b\u043b\u0438 \u0441\u043e\u043e\u0442\u0432\u0435\u0442\u0441\u0442\u0432\u0443\u044e\u0449\u0438\u0445 \n\u043a\u043e\u043d\u0441\u043e\u043b\u0438\u0434\u0438\u0440\u0443\u0435\u043c\u044b\u0445 \u043a\u043e\u043c\u043f\u0430\u043d\u0438\u0439. \n 2021 \u0433\u043e\u0434 2020 \u0433\u043e\u0434 \n \n\u041f\u0440\u0438\u0431\u044b\u043b\u044c \u0434\u043e \u043d\u0430\u043b\u043e\u0433\u043e\u043e\u0431\u043b\u043e\u0436\u0435\u043d\u0438\u044f 5 088 3 575 \n\u041d\u0430\u043b\u043e\u0433, \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043d\u043d\u044b\u0439 \u043f\u043e \u0441\u0442\u0430\u0432\u043a\u0435 20% (1 018) (715) \n\u042d\u0444\u0444\u0435\u043a\u0442 \u0440\u0435\u0433\u0438\u043e\u043d\u0430\u043b\u044c\u043d\u044b\u0445 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0445 \u0441\u0442\u0430\u0432\u043e\u043a, \u043e\u0442\u043b\u0438\u0447\u043d\u044b\u0445 \u043e\u0442 20% 181 165 \n\u041a\u043e\u0440\u0440\u0435\u043a\u0442\u0438\u0440\u043e\u0432\u043a\u0430 \u043d\u0430\u043b\u043e\u0433\u0430, \u0440\u0430\u0441\u0441\u0447\u0438\u0442\u0430\u043d\u043d\u043e\u0433\u043e \u0437\u0430 \u043f\u0440\u043e\u0448\u043b\u044b\u0435 \u043f\u0435\u0440\u0438\u043e\u0434\u044b (54) (78) \n\u042d\u0444\u0444\u0435\u043a\u0442 \u0440\u0430\u0441\u0445\u043e\u0434\u043e\u0432, \u043d\u0435 \u043f\u0440\u0438\u043d\u0438\u043c\u0430\u0435\u043c\u044b\u0445 \u0432 \u0446\u0435\u043b\u044f\u0445 \u043d\u0430\u043b\u043e\u0433\u043e\u043e\u0431\u043b\u043e\u0436\u0435\u043d\u0438\u044f (320) (146) \n\u0418\u0442\u043e\u0433\u043e \u0440\u0430\u0441\u0445\u043e\u0434 \u043f\u043e \u043d\u0430\u043b\u043e\u0433\u0443 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c (1 211) (774) \n25. \u041e\u0422\u041b\u041e\u0416\u0415\u041d\u041d\u042b\u0419 \u041d\u0410\u041b\u041e\u0413 \n\u041d\u0438\u0436\u0435 \u043f\u0440\u0438\u0432\u0435\u0434\u0435\u043d\u044b \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u043e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0435 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b \u0438 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u0430, \u043f\u0440\u0438\u0437\u043d\u0430\u043d\u043d\u044b\u0435 \u0413\u0440\u0443\u043f\u043f\u043e\u0439, \n\u0438 \u0438\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u043d\u0438\u0445 \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u043e\u0442\u0447\u0435\u0442\u043d\u043e\u0433\u043e \u043f\u0435\u0440\u0438\u043e\u0434\u0430. "}
