\u0431\u043b\u044f \u043e\u0442\u043d\u043e\u0441\u0438\u0442\u0435\u043b\u044c\u043d\u043e \u043e\u0441\u043d\u043e\u0432\u043d\u044b\u0445 \u0432\u0430\u043b\u044e\u0442 \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u043e\u0442\u0447\u0435\u0442\u043d\u043e\u0433\u043e \u043f\u0435\u0440\u0438\u043e\u0434\u0430 \n(\u043e\u0431\u0435\u0441\u0446\u0435\u043d\u0435\u043d\u0438\u044f \u0432 \u0442\u0435\u0447\u0435\u043d\u0438\u0435 \u0441\u0440\u0430\u0432\u043d\u0438\u0442\u0435\u043b\u044c\u043d\u043e\u0433\u043e \u043f\u0435\u0440\u0438\u043e\u0434\u0430). \n\u0420\u0435\u0437\u0435\u0440\u0432 \u043a\u0443\u0440\u0441\u043e\u0432\u044b\u0445 \u0440\u0430\u0437\u043d\u0438\u0446 \u043f\u0440\u0438 \u043f\u0435\u0440\u0435\u0441\u0447\u0435\u0442\u0435 \u043e\u043f\u0435\u0440\u0430\u0446\u0438\u0439 \u0432 \u0438\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u043e\u0439 \u0432\u0430\u043b\u044e\u0442\u0435 \n\u041a\u0440\u043e\u043c\u0435 \u0442\u043e\u0433\u043e, \u0447\u0438\u0441\u0442\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b \u0434\u043e\u0447\u0435\u0440\u043d\u0438\u0445 \u0438\u043d\u043e\u0441\u0442\u0440\u0430\u043d\u043d\u044b\u0445 \u043f\u0440\u0435\u0434\u043f\u0440\u0438\u044f\u0442\u0438\u0439 \u0413\u0440\u0443\u043f\u043f\u044b, \u0434\u0435\u043d\u043e\u043c\u0438\u043d\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0435 \u0432 \u0434\u043e\u043b\u043b\u0430\u0440\u0430\u0445 "}
