50) \n(\u0423\u043c\u0435\u043d\u044c\u0448\u0435\u043d\u0438\u0435)/\u0443\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u043f\u0440\u043e\u0447\u0438\u0445 \u043e\u0431\u044f\u0437\u0430\u0442\u0435\u043b\u044c\u0441\u0442\u0432 (44) 47 \n\u0423\u0432\u0435\u043b\u0438\u0447\u0435\u043d\u0438\u0435 \u043a\u0440\u0435\u0434\u0438\u0442\u043e\u0440\u0441\u043a\u043e\u0439 \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u0438 \u043f\u043e \u043f\u0440\u043e\u0447\u0438\u043c \u043d\u0430\u043b\u043e\u0433\u0430\u043c 182 521 "}
{"name": "MVID", "date": "2024", "content": "\u041e\u0441\u043d\u043e\u0432\u043d\u044b\u0435 \u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430 11 021 13 204 \n\u0418\u043d\u0432\u0435\u0441\u0442\u0438\u0446\u0438\u043e\u043d\u043d\u0430\u044f \u043d\u0435\u0434\u0432\u0438\u0436\u0438\u043c\u043e\u0441\u0442\u044c 184 374 \n\u041d\u0435\u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b 23 612 26 764 \n\u0413\u0443\u0434\u0432\u0438\u043b 50 007 50 007 \n\u041e\u0442\u043b\u043e\u0436\u0435\u043d\u043d\u044b\u0435 \u043d\u0430\u043b\u043e\u0433\u043e\u0432\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b 7 661 6 749 \n\u041f\u0440\u043e\u0447\u0438\u0435 \u0432\u043d\u0435\u043e\u0431\u043e\u0440\u043e\u0442\u043d\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b 1 629 1 703 \n\u0418\u0442\u043e\u0433\u043e \u0432\u043d\u0435\u043e\u0431\u043e\u0440\u043e\u0442\u043d\u044b\u0435 \u0430\u043a\u0442\u0438\u0432\u044b 94 114 98 801 \n\u041e\u0411\u041e\u0420\u041e\u0422\u041d\u042b\u0415 \u0410\u041a\u0422\u0418\u0412\u042b \n\u0422\u043e\u0432\u0430\u0440\u043d\u043e\u2013\u043c\u0430\u0442\u0435\u0440\u0438\u0430\u043b\u044c\u043d\u044b\u0435 \u0437\u0430\u043f\u0430\u0441\u044b 139 702 112 871 \n\u0414\u0435\u0431\u0438\u0442\u043e\u0440\u0441\u043a\u0430\u044f \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c 30 803 17 792 \n\u0410\u0432\u0430\u043d\u0441\u044b \u0432\u044b\u0434\u0430\u043d\u043d\u044b\u0435 10 050 11 314 \n\u0414\u0435\u0431\u0438\u0442\u043e\u0440\u0441\u043a\u0430\u044f \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u043d\u0430\u043b\u043e\u0433\u0443 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c 64 239 \n\u0414\u0435\u0431\u0438\u0442\u043e\u0440\u0441\u043a\u0430\u044f \u0437\u0430\u0434\u043e\u043b\u0436\u0435\u043d\u043d\u043e\u0441\u0442\u044c \u043f\u043e \u043f\u0440\u043e\u0447\u0438\u043c \u043d