38\u043c\u043e \u043e\u0442 \u043f\u0440\u0438\u0447\u0438\u043d \u043d\u0435 \u0431\u044b\u043b\u043e \n\u043f\u0440\u0438\u043d\u044f\u0442\u043e \u0440\u0435\u0448\u0435\u043d\u0438\u0435 \u043e \u0432\u044b\u043f\u043b\u0430\u0442\u0435 \u0434\u0438\u0432\u0438\u0434\u0435\u043d\u0434\u043e\u0432 \u0438\u043b\u0438 \u0431\u044b\u043b\u043e \u043f\u0440\u0438\u043d\u044f\u0442\u043e \u0440\u0435\u0448\u0435\u043d\u0438\u0435 \u043e \u043d\u0435\u043f\u043e\u043b\u043d\u043e\u0439 \u0432\u044b\u043f\u043b\u0430\u0442\u0435 \u0434\u0438\u0432\u0438\u0434\u0435\u043d\u0434\u043e\u0432 \u043f\u043e \n\u043f\u0440\u0438\u0432\u0438\u043b\u0435\u0433\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u043c \u0430\u043a\u0446\u0438\u044f\u043c. \u041f\u0440\u0430\u0432\u043e \u0432\u043b\u0430\u0434\u0435\u043b\u044c\u0446\u0435\u0432 \u043f\u0440\u0438\u0432\u0438\u043b\u0435\u0433 \u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0445 \u0430\u043a\u0446\u0438\u0439 \u0443\u0447\u0430\u0441\u0442\u0432\u043e\u0432\u0430\u0442\u044c \u0432 \u041e\u0431\u0449\u0435\u043c \n\u0441\u043e\u0431\u0440\u0430\u043d\u0438\u0438 \u0430\u043a\u0446\u0438\u043e\u043d\u0435\u0440\u043e\u0432 \u041e\u0431\u0449\u0435\u0441\u0442\u0432\u0430 \u043f\u0440\u0435\u043a\u0440\u0430\u0449\u0430\u0435\u0442\u0441\u044f \u0441 \u043c\u043e\u043c\u0435\u043d\u0442\u0430 \u043f\u0435\u0440\u0432\u043e\u0439 \u0432\u044b\u043f\u043b\u0430\u0442\u044b \u043f\u043e \u0443\u043a\u0430\u0437\u0430\u043d\u043d\u044b\u043c \u0430\u043a\u0446\u0438\u044f\u043c "}
