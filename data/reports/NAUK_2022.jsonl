0438, \u043f\u043e\u043b\u0443\u0447\u0435\u043d\u043d\u043e\u0439 \u043e\u0442 \u043f\u0440\u043e\u0438\u0437\u0432\u043e\u0434\u0441\u0442\u0432\u0430 \u0438 \n\u0440\u0435\u0430\u043b\u0438\u0437\u0430\u0446\u0438\u0438 \u043f\u0440\u043e\u0434\u0443\u043a\u0446\u0438\u0438 \u0438 \u041d\u0418\u041e\u041a\u0420 \u043d\u0430 \u0442\u0435\u0440\u0440\u0438\u0442\u043e\u0440\u0438\u0438 \u043e\u0431\u044a\u0435\u043a\u0442\u043e\u0432, \u043a\u043e\u0442\u043e\u0440\u044b\u043c \u043f\u0440\u0430\u0432\u0438\u0442\u0435\u043b\u044c\u0441\u0442\u0432\u043e\u043c \u0433. \u041c\u043e\u0441\u043a\u0432\u044b \n\u043f\u0440\u0438\u0441\u0432\u043e\u0435\u043d \u0441\u0442\u0430\u0442\u0443\u0441 \u043f\u0440\u043e\u043c\u044b\u0448\u043b\u0435\u043d\u043d\u043e\u0433\u043e \u043a\u043e\u043c\u043f\u043b\u0435\u043a\u0441\u0430, \u0438 \u0437\u0430\u0447\u0438\u0441\u043b\u044f\u0435\u043c\u043e\u0439 \u0432 \u0441\u0443\u0431\u044a\u0435\u043a\u0442 \u0433. \u041c\u043e\u0441\u043a\u0432\u044b, \u0441\u043e\u0441\u0442\u0430\u0432\u043b\u044f\u0435\u0442 \n12,5%. \u041f\u0440\u0438 \u0440\u0430\u0441\u0447\u0435\u0442\u0435 \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c \u0434\u043b\u044f \u0432\u0441\u0435\u0445 \u0440\u0430\u0441\u0447\u0435\u0442\u043e\u0432 \u0438\u0441\u043f\u043e\u043b\u044c\u0437\u0443\u0435\u0442\u0441\u044f \u0441\u0442\u0430\u0432\u043a\u0430 \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c, \n\u0443\u0441\u0442\u0430\u043d\u043e\u0432\u043b\u0435\u043d\u043d\u0430\u044f \u041d\u041a \u0420\u0424 \u0431\u0435\u0437 \u0443\u0447\u0435\u0442\u0430 \u0437\u0430\u043a\u043e\u043d\u0430 \u0441\u0443\u0431\u044a\u0435\u043a\u0442\u0430 \u0420\u0424. \u041f\u0440\u0438 \u0440\u0430\u0441\u0447\u0435\u0442\u0435 \u0443\u0441\u043b\u043e\u0432\u043d\u043e\u0433\u043e \u043d\u0430\u043b\u043e\u0433\u0430 \u043d\u0430 \u043f\u0440\u0438\u0431\u044b\u043b\u044c \n\u0