\u043d\u0435\u0442\u0442\u043e \u2013 101 \n\u0418\u0437\u043c\u0435\u043d\u0435\u043d\u0438\u044f \u0440\u0435\u0437\u0435\u0440\u0432\u0430 \u043f\u043e\u0434 \u043e\u0436\u0438\u0434\u0430\u0435\u043c\u044b\u0435 \u043a\u0440\u0435\u0434\u0438\u0442\u043d\u044b\u0435 \u0443\u0431\u044b\u0442\u043a\u0438 \u043f\u043e \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u043c \n\u0441\u0440\u0435\u0434\u0441\u0442\u0432\u0430\u043c \u0438 \u0438\u0445 \u044d\u043a\u0432\u0438\u0432\u0430\u043b\u0435\u043d\u0442\u0430\u043c 354 28 547 \n\u0427\u0438\u0441\u0442\u043e\u0435 \u0443\u043c\u0435\u043d\u044c\u0448\u0435\u043d\u0438\u0435 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0438 \u0438\u0445 \u044d\u043a\u0432\u0438\u0432\u0430\u043b\u0435\u043d\u0442\u043e\u0432 (291 919) (2 069 210) \n\u041f\u0410\u041e \u00ab\u0418\u0436\u0441\u0442\u0430\u043b\u044c\u00bb \n\u041e\u0431\u043e\u0431\u0449\u0435\u043d\u043d\u044b\u0439 \u043a \u043e\u043d\u0441\u043e\u043b\u0438\u0434\u0438\u0440\u043e\u0432\u0430\u043d\u043d\u044b\u0439 \u043e\u0442\u0447\u0435\u0442 \u043e \u0434\u0432\u0438\u0436\u0435\u043d\u0438\u0438 \u0434\u0435\u043d\u0435\u0436\u043d\u044b\u0445 \u0441\u0440\u0435\u0434\u0441\u0442\u0432 \u0437\u0430 \u0433\u043e\u0434, \u0437\u0430\u043a\u043e\u043d\u0447\u0438\u0432\u0448\u0438\u0439\u0441\u044f \n31 \u0434\u0435\u043a\u0430\u0431\u0440\u044f 2024 \u0433. "}
